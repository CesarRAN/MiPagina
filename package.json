{
  "name": "mi-pagina",
  "version": "1.0.0",
  "description": "Página web personal con parallax, responsive y tema oscuro verde lima",
  "scripts": {
    "build": "npx tailwindcss -i ./css/styles.css -o ./css/output.css --watch",
    "build:prod": "npx tailwindcss -i ./css/styles.css -o ./css/output.css --minify"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "jsdom": "^29.1.1",
    "marked": "^18.0.5",
    "multer": "^2.2.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "playwright": "^1.61.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
